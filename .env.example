# Kopier denne fila til ".env" og fyll inn dine egne Garmin Connect-detaljer.
# .env ligger i .gitignore og blir ALDRI delt eller lastet opp noe sted.

GARMIN_EMAIL=din.epost@example.com
GARMIN_PASSWORD=ditt-garmin-passord

# Valgfritt: hvor innloggingstokenene lagres (standard: ~/.garminconnect)
# GARMINTOKENS=~/.garminconnect

# --- Fase 3: Golfbox ---
# Innlogging skjer i nettleseren (økten huskes), så disse er valgfrie.
GOLFBOX_USERNAME=ditt-golfbox-brukernavn
GOLFBOX_PASSWORD=ditt-golfbox-passord

# Valgfri standard-markør – fylles inn automatisk (du bekrefter med «Søk» i Golfbox).
# Bruk ENTEN medlemsnummer ELLER navn.
# GOLFBOX_MARKER_MEMBERNO=123456
# GOLFBOX_MARKER_NAME=Ola Nordmann

# --- Sentral base (delt bane-database via Supabase) – valgfritt ---
# Se SENTRALISERING.md. Uten disse kjører alt lokalt som før.
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
